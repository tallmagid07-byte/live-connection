# Copiez ce fichier en .env.local et remplissez avec vos vraies clés

# Dashboard Supabase > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# URL publique de votre app (locale ou celle de Vercel une fois déployée)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google Cloud Console > APIs & Services > Credentials
NEXT_PUBLIC_YOUTUBE_API_KEY=your-youtube-api-key

# Dashboard Supabase > Project Settings > API > "service_role" secret key
# ATTENTION : ne jamais mettre le préfixe NEXT_PUBLIC_ devant celle-ci,
# sinon elle serait exposée publiquement dans le navigateur.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Choisissez vous-même une phrase secrète (ex: un mot de passe aléatoire).
# Elle protège la route /api/ping pour que seul UptimeRobot puisse l'appeler.
PING_SECRET=choose-a-random-secret-phrase
